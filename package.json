{
  "type": "module",
  "name": "krd-typescript-template",
  "version": "1.0.0",
  "description": "A node typescript project template for the Kordis landscape",
  "main": "./dist/index.js",
  "scripts": {
    "start:dev": "tsc-watch --onSuccess \"node ./dist/index.js\"",
    "start": "node ./dist/index.js",
    "test": "jest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "build:release": "tsc --build tsconfig.release.json",
    "prepare": "husky install"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "jest": "30.4.2",
    "prettier": "3.9.5",
    "ts-jest": "29.4.11",
    "tsc-watch": "7.2.1",
    "typescript": "7.0.2"
  },
  "lint-staged": {
    "*.ts": "eslint --cache --fix",
    "*.{ts,md,graphql,json}": "prettier --write"
  }
}
